FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      createPatchDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// dummy file to clean zero-size patches via createPatch
pointSync false;

// Patches to create.
patches
(
	{
        // Name of new patch
        name wallInsideLambda;

        // Type of new patch
        patchInfo
        {
            type wall;
        }

        // How to construct: either from 'patches' or 'set'
        constructFrom set;

        // If constructFrom = set : name of faceSet
        set bFacesInsideLambda;
	}
);


